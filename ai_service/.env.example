# ================================
# GLM配置
# ================================
GLM_API_KEY=your_api_key_here
GLM_MODEL=glm-4-flash
GLM_TEMPERATURE=0.1
GLM_MAX_TOKENS=8000
GLM_TIMEOUT=60

# ================================
# 服务配置
# ================================
SERVICE_PORT=8000
SERVICE_HOST=0.0.0.0
DEBUG=false
ENVIRONMENT=development

# ================================
# 日志配置
# ================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# ================================
# 限制配置
# ================================
MAX_CONTENT_LENGTH=10485760
MAX_QUESTIONS_PER_REQUEST=50